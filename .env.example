# ══════════════════════════════════════════════════════════════
# WebOwnr Cyan — Environment Variables
# Copy this file to .env.local and fill in every value.
# NEVER commit .env.local to version control.
# On Vercel: add each variable in Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ── Firebase Client SDK (safe for browser — NEXT_PUBLIC_ prefix required) ────
# Get these from: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin SDK (server-side only — NO NEXT_PUBLIC_ prefix) ───────────
# 1. Go to: Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → downloads a JSON file
# 3. Base64-encode it:
#      Mac/Linux: base64 -i serviceAccountKey.json | tr -d '\n'
#      Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
# 4. Paste the result below (one long string, no line breaks)
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Anthropic API Key (server-side only — NEVER expose to client) ─────────────
# Get from: https://console.anthropic.com → API Keys → Create Key
# Required scopes: claude-haiku-4-5-20251001, claude-sonnet-4-5
ANTHROPIC_API_KEY=

# ── App URL ────────────────────────────────────────────────────────────────────
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (your Vercel URL — set this after first deploy):
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
